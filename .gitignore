# ---------------------------------
# Terraform state files (CRITICAL)
# ---------------------------------
*.tfstate
*.tfstate.*
*.backup

# Terraform crash logs
crash.log

# Terraform local cache
.terraform/

# Terraform lock file
# Usually COMMIT this file for team consistency
# Uncomment next line only if intentionally ignoring it
# .terraform.lock.hcl

# CLI config files
terraform.rc
terraform.rc.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Variable files containing secrets
*.tfvars
*.tfvars.json

# Exception:
# Keep example variable files
!terraform.tfvars.example

# Plan files
*.tfplan
tfplan

# ---------------------------------
# IDE / Editor
# ---------------------------------
.vscode/
.idea/

# ---------------------------------
# OS files
# ---------------------------------
.DS_Store
Thumbs.db

# ---------------------------------
# Logs
# ---------------------------------
*.log